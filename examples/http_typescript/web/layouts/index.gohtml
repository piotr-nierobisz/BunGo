<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{.PageTitle}}</title>
    <style>
        :root {
            --bg: #0f0f12;
            --surface: #1a1a20;
            --text: #e8e8ed;
            --text-muted: #9090a0;
            --accent: #6366f1;
            --accent-hover: #818cf8;
            --border: #2a2a32;
            --radius: 10px;
            --font: "DM Sans", -apple-system, BlinkMacSystemFont, sans-serif;
        }
        * { box-sizing: border-box; }
        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            margin: 0;
            min-height: 100vh;
            padding: 0 1.5rem 3rem;
        }
        .page-wrap { max-width: 720px; margin: 0 auto; }
        .page-header {
            padding: 2rem 0 1rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 2rem;
        }
        .page-header h1 { margin: 0 0 0.25rem; font-size: 1.75rem; font-weight: 600; color: var(--text); }
        .page-header p { margin: 0; color: var(--text-muted); font-size: 0.95rem; }
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.75rem;
            margin-top: 1.5rem;
        }
        .card h2 { margin: 0 0 1rem; font-size: 1.25rem; font-weight: 600; color: var(--text); border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
        .card p { margin: 0.5rem 0; color: var(--text-muted); font-size: 0.95rem; }
        .card p:last-of-type { margin-bottom: 1rem; }
        .btn {
            display: inline-block;
            background: var(--accent);
            color: #fff;
            font-family: inherit;
            font-weight: 600;
            font-size: 0.95rem;
            padding: 0.65rem 1.25rem;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.15s;
        }
        .btn:hover { background: var(--accent-hover); }
        #root { margin-top: 1rem; }
    </style>
</head>
<body>
    <div class="page-wrap">
        <header class="page-header">
            <h1>{{.PageTitle}}</h1>
            <p>This page uses a TSX view with BunGo auto-injected helpers and remote ESM imports.</p>
        </header>
        <div id="root"></div>
    </div>
</body>
</html>
