<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BunGo Remote Imports</title>
    <style>
        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #0d1117;
            color: #e6edf3;
        }
        .wrapper {
            max-width: 980px;
            margin: 0 auto;
            padding: 2rem 1rem 3rem;
        }
        h1 {
            margin: 0 0 0.5rem;
        }
        .muted {
            color: #8b949e;
            margin: 0 0 1.5rem;
        }
        .card {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 1rem;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <h1>Remote ESM Imports in JSX</h1>
        <p class="muted">This view imports recharts and date-fns directly from esm.sh.</p>
        <div class="card">
            <div id="root"></div>
        </div>
    </div>
</body>
</html>
